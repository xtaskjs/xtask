{
  "name": "19-cqrs_app",
  "version": "1.0.0",
  "description": "xTaskJS CQRS sample with separate read and write SQLite databases.",
  "main": "index.js",
  "scripts": {
    "prestart": "npm run build --prefix ../../packages/cqrs",
    "start": "ts-node -r tsconfig-paths/register ./src/app.ts",
    "prebuild": "npm run build --prefix ../../packages/cqrs",
    "build": "npm run clean; tsc",
    "clean": "rm -rf dist",
    "start:parallel": "XTASK_SCAN_WORKERS=auto ts-node -r tsconfig-paths/register ./src/app.ts",
    "test": "ts-node -r tsconfig-paths/register ./src/app.spec.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@xtaskjs/common": "file:../../packages/common",
    "@xtaskjs/core": "file:../../packages/core",
    "@xtaskjs/cqrs": "file:../../packages/cqrs",
    "@xtaskjs/typeorm": "file:../../packages/typeorm",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "@xtaskjs/testing": "file:../../packages/testing"
  }
}
