{
  "name": "21-event_source_rabbitmq_app",
  "version": "1.0.0",
  "description": "xTaskJS event-source sample with TypeORM-backed event storage and RabbitMQ delivery.",
  "main": "index.js",
  "scripts": {
    "prestart": "pnpm -C ../../packages/event-source build",
    "start": "ts-node -r tsconfig-paths/register ./src/app.ts",
    "build": "npm run clean; tsc",
    "clean": "rm -rf dist",
    "rabbitmq:up": "docker compose up -d",
    "rabbitmq:down": "docker compose down",
    "start:parallel": "XTASK_SCAN_WORKERS=auto ts-node -r tsconfig-paths/register ./src/app.ts",
    "test": "ts-node -r tsconfig-paths/register ./src/app.spec.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@xtaskjs/common": "workspace:*",
    "@xtaskjs/core": "workspace:*",
    "@xtaskjs/event-source": "workspace:*",
    "@xtaskjs/queues": "workspace:*",
    "@xtaskjs/typeorm": "workspace:*",
    "@xtaskjs/validation": "workspace:*",
    "amqplib": "^0.10.9",
    "reflect-metadata": "^0.2.2",
    "sqlite3": "^5.1.7",
    "ts-morph": "^27.0.0",
    "typeorm": "^0.3.28",
    "zod": "^3.25.76",
    "@xtaskjs/config": "workspace:*"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "@xtaskjs/testing": "workspace:*"
  }
}
