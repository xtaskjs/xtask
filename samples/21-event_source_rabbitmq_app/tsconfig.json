{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./",
    "paths": {
      "@xtaskjs/common": ["../../packages/common/dist"],
      "@xtaskjs/common/*": ["../../packages/common/dist/*"],
      "@xtaskjs/core": ["../../packages/core/dist"],
      "@xtaskjs/core/*": ["../../packages/core/dist/*"],
      "@xtaskjs/event-source": ["../../packages/event-source/dist"],
      "@xtaskjs/event-source/*": ["../../packages/event-source/dist/*"],
      "@xtaskjs/queues": ["../../packages/queues/dist"],
      "@xtaskjs/queues/*": ["../../packages/queues/dist/*"],
      "@xtaskjs/typeorm": ["../../packages/typeorm/dist"],
      "@xtaskjs/typeorm/*": ["../../packages/typeorm/dist/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}