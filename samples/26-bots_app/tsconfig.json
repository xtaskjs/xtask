{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./",
    "paths": {
      "@xtaskjs/config": [
        "../../packages/config/dist/cjs/index.js",
        "../../packages/config/src/index.ts"
      ],
      "@xtaskjs/config/*": [
        "../../packages/config/dist/cjs/*",
        "../../packages/config/src/*"
      ],
      "zod": [
        "../../packages/config/node_modules/zod"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
