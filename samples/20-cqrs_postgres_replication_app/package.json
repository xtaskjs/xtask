{
  "name": "20-cqrs_postgres_replication_app",
  "version": "1.0.0",
  "description": "xTaskJS CQRS sample with PostgreSQL master/slave replication in Docker.",
  "main": "index.js",
  "scripts": {
    "prestart": "pnpm -C ../../packages/cqrs build",
    "start": "ts-node -r tsconfig-paths/register ./src/app.ts",
    "build": "npm run clean; tsc",
    "clean": "rm -rf dist",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down -v",
    "docker:logs": "docker-compose logs -f postgres-master postgres-slave",
    "start:parallel": "XTASK_SCAN_WORKERS=auto ts-node -r tsconfig-paths/register ./src/app.ts",
    "test": "ts-node -r tsconfig-paths/register ./src/app.spec.ts"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@xtaskjs/common": "workspace:*",
    "@xtaskjs/core": "workspace:*",
    "@xtaskjs/cqrs": "workspace:*",
    "@xtaskjs/typeorm": "workspace:*",
    "@xtaskjs/validation": "workspace:*",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "@xtaskjs/testing": "workspace:*"
  }
}
