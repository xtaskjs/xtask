{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "rootDir": "./",
    "outDir": "dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./",
    "paths": {
      "@xtaskjs/common": [
        "../../packages/common/dist/cjs/index.js"
      ],
      "@xtaskjs/core": [
        "../../packages/core/dist/cjs/index.js"
      ],
      "@xtaskjs/fastify-http": [
        "../../packages/fastify-http/dist/cjs/index.js"
      ],
      "@xtaskjs/testing": [
        "../../packages/testing/dist/cjs/index.js"
      ],
      "@xtaskjs/testing/*": [
        "../../packages/testing/dist/cjs/*"
      ],
      "@xtaskjs/config": [
        "../../packages/config/dist/cjs/index.js",
        "../../packages/config/src/index.ts"
      ],
      "@xtaskjs/config/*": [
        "../../packages/config/dist/cjs/*",
        "../../packages/config/src/*"
      ],
      "zod": [
        "../../packages/config/node_modules/zod"
      ]
    }
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
