# Server
PORT=3000

# Mailtrap SMTP
MAILTRAP_SMTP_USER=your-mailtrap-username
MAILTRAP_SMTP_PASS=your-mailtrap-password
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_SECURE=false

# Sender addresses
MAIL_FROM=hello@xtaskjs.dev
MAIL_NOTIFICATIONS_FROM=alerts@xtaskjs.dev

# Internal recipients
MAIL_NOTIFICATIONS_TO=ops@xtaskjs.dev
MAIL_SUPPORT_TO=support@xtaskjs.dev