{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./",
    "paths": {
      "@xtaskjs/common": ["packages/common/src/index.ts"],
      "@xtaskjs/common/*": ["packages/common/src/*"],
      "@xtaskjs/core": ["packages/core/src/index.ts"],
      "@xtaskjs/core/*": ["packages/core/src/*"],
      "@xtaskjs/value-objects": ["packages/value-objects/src/index.ts"],
      "@xtaskjs/value-objects/*": ["packages/value-objects/src/*"],
      "@xtaskjs/express-http": ["packages/express-http/src/index.ts"],
      "@xtaskjs/express-http/*": ["packages/express-http/src/*"],
      "@xtaskjs/fastify-http": ["packages/fastify-http/src/index.ts"],
      "@xtaskjs/fastify-http/*": ["packages/fastify-http/src/*"],
      "@xtaskjs/typeorm": ["packages/typeorm/src/index.ts"],
      "@xtaskjs/typeorm/*": ["packages/typeorm/src/*"],
      "@xtaskjs/security": ["packages/security/src/index.ts"],
      "@xtaskjs/security/*": ["packages/security/src/*"],
      "@xtaskjs/mailer": ["packages/mailer/src/index.ts"],
      "@xtaskjs/mailer/*": ["packages/mailer/src/*"],
      "@xtaskjs/cache": ["packages/cache/src/index.ts"],
      "@xtaskjs/cache/*": ["packages/cache/src/*"],
      "@xtaskjs/scheduler": ["packages/scheduler/src/index.ts"],
      "@xtaskjs/scheduler/*": ["packages/scheduler/src/*"],
      "@xtaskjs/queues": ["packages/queues/src/index.ts"],
      "@xtaskjs/queues/*": ["packages/queues/src/*"],
      "@xtaskjs/internationalization": ["packages/internationalization/src/index.ts"],
      "@xtaskjs/internationalization/*": ["packages/internationalization/src/*"]
    }
  },
  "include": ["packages/**/*","packages/**/**/*","packages/**/**/**/*","samples/**/*","samples/**/**/*"],
  "exclude": ["node_modules", "dist"]
}