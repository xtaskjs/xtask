{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./",
    "outDir": "dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": "./",
    "paths": {
      "@xtaskjs/common": ["packages/common"],
      "@xtaskjs/core": ["packages/core"],
      "@xtaskjs/express-http": ["packages/express-http"],
      "@xtaskjs/fastify-http": ["packages/fastify-http"]
    }
  },
  "include": ["packages/**/*","packages/**/**/*","packages/**/**/**/*","samples/**/*","samples/**/**/*"],
  "exclude": ["node_modules", "dist"]
}