{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@xtaskjs/common": ["../common/src"],
      "@xtaskjs/common/*": ["../common/src/*"],
      "@xtaskjs/express-http": ["../express-http/src"],
      "@xtaskjs/express-http/*": ["../express-http/src/*"],
      "@xtaskjs/fastify-http": ["../fastify-http/src"],
      "@xtaskjs/fastify-http/*": ["../fastify-http/src/*"],
      "@xtaskjs/security": ["../security/src"],
      "@xtaskjs/security/*": ["../security/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "../common/src/**/*",
    "../express-http/src/**/*",
    "../fastify-http/src/**/*",
    "../security/src/**/*"
  ]
}