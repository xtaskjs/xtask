{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths":{
      "@xtaskjs/common": ["../common/dist"],
      "@xtaskjs/common/*": ["../common/dist/*"],
      "@xtaskjs/express-http": ["../express-http/src"],
      "@xtaskjs/express-http/*": ["../express-http/src/*"],
      "@xtaskjs/fastify-http": ["../fastify-http/src"],
      "@xtaskjs/fastify-http/*": ["../fastify-http/src/*"]
    },
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}