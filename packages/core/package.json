{
  "name": "@xtaskjs/core",
  "version": "1.0.46",
  "description": "Core application runtime and DI container for xtaskjs.",
  "author": "Javier Rodríguez Soler",
  "homepage": "https://xtaskjs.io",
  "main": "dist/cjs/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "prebuild:manifest": "rm -rf .prebuild-cjs && pnpm exec tsc --outDir .prebuild-cjs --module commonjs && node -e \"require('fs').writeFileSync('.prebuild-cjs/package.json', JSON.stringify({ type: 'commonjs' }, null, 2))\" && node ./.prebuild-cjs/cli-build/prebuild.js && rm -rf .prebuild-cjs",
    "build": "rm -rf dist && tsc --outDir dist/cjs && node ../../scripts/postbuild-dual.mjs packages/core",
    "prepack": "pnpm build",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "coverage:open": "xdg-open coverage/lcov-report/index.html",
    "benchmark:startup": "TS_NODE_PROJECT=../../tsconfig.json node --expose-gc -r ts-node/register/transpile-only -r tsconfig-paths/register ./scripts/startup-benchmark.ts"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/xtaskjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xtaskjs/xtask.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/xtaskjs/xtask/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@xtaskjs/common": "workspace:^"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.1.12 || ^0.2.0"
  },
  "peerDependenciesMeta": {
    "class-validator": {
      "optional": true
    },
    "class-transformer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  },
  "module": "dist/esm/index.js"
}
