{
  "name": "@xtaskjs/throttler",
  "version": "1.0.16",
  "description": "Rate limiting (throttler) integration for xtaskjs.",
  "author": "Javier Rodriguez Soler",
  "homepage": "https://xtaskjs.io",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "prepack": "pnpm build",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "coverage:open": "xdg-open coverage/lcov-report/index.html"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/xtaskjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xtaskjs/xtask.git",
    "directory": "packages/throttler"
  },
  "bugs": {
    "url": "https://github.com/xtaskjs/xtask/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@xtaskjs/common": "workspace:^",
    "@xtaskjs/core": "workspace:^"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.1.12 || ^0.2.0"
  },
  "peerDependenciesMeta": {
    "redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "vitest": "^2.1.8",
    "@vitest/coverage-v8": "^2.1.8"
  }
}
