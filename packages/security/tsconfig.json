{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@xtaskjs/common": ["../../dist/packages/common"],
      "@xtaskjs/common/*": ["../../dist/packages/common/*"],
      "@xtaskjs/core": ["../../dist/packages/core"],
      "@xtaskjs/core/*": ["../../dist/packages/core/*"]
    },
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}