{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@xtaskjs/core": ["../core/src"],
      "@xtaskjs/core/*": ["../core/src/*"]
    }
  },
  "include": ["src/**/*", "test/**/*", "../core/src/**/*"]
}