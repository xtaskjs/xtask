  },
  "license": "MIT",
  "dependencies": {
    "@xtaskjs/core": "^1.0.14",
    "ejs": "^3.1.10",
    "handlebars": "^4.7.8",
    "nodemailer": "^6.10.1"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.1.12 || ^0.2.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@jest/globals": "^30.1.2",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^6.4.17",
    "jest": "^30.1.3",
    "nodemon": "^3.1.10",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2"
