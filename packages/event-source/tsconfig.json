{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@xtaskjs/core": [
        "../core/dist/cjs"
      ],
      "@xtaskjs/core/*": [
        "../core/dist/cjs/*"
      ],
      "@xtaskjs/typeorm": [
        "../typeorm/dist/cjs"
      ],
      "@xtaskjs/typeorm/*": [
        "../typeorm/dist/cjs/*"
      ],
      "@xtaskjs/queues": [
        "../queues/dist/cjs"
      ],
      "@xtaskjs/queues/*": [
        "../queues/dist/cjs/*"
      ]
    },
    "declaration": true,
    "incremental": true,
    "composite": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
