{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "dist",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@xtaskjs/core": ["../core/dist"],
      "@xtaskjs/core/*": ["../core/dist/*"],
      "@xtaskjs/typeorm": ["../typeorm/dist"],
      "@xtaskjs/typeorm/*": ["../typeorm/dist/*"],
      "@xtaskjs/queues": ["../queues/dist"],
      "@xtaskjs/queues/*": ["../queues/dist/*"]
    },
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}