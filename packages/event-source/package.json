{
  "name": "@xtaskjs/event-source",
  "version": "1.0.23",
  "description": "Event sourcing integration for xtaskjs with aggregate repositories, lifecycle wiring, and optional TypeORM and queue adapters.",
  "author": "Javier Rodriguez Soler",
  "homepage": "https://xtaskjs.io",
  "main": "dist/cjs/index.js",
  "types": "dist/cjs/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/cjs/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "default": "./dist/esm/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc --outDir dist/cjs && node ../../scripts/postbuild-dual.mjs packages/event-source",
    "prepack": "pnpm build",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "coverage:open": "xdg-open coverage/lcov-report/index.html"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/xtaskjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xtaskjs/xtask.git",
    "directory": "packages/event-source"
  },
  "bugs": {
    "url": "https://github.com/xtaskjs/xtask/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@xtaskjs/core": "workspace:^",
    "@xtaskjs/queues": "workspace:^",
    "@xtaskjs/typeorm": "workspace:^"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.1.12 || ^0.2.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "sql.js": "^1.13.0",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.27",
    "typescript": "^5.9.2",
    "vitest": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7"
  },
  "module": "dist/esm/index.js"
}
