{
  "name": "@xtaskjs/event-source",
  "version": "1.0.4",
  "description": "Event sourcing integration for xtaskjs with aggregate repositories, lifecycle wiring, and optional TypeORM and queue adapters.",
  "author": "Javier Rodriguez Soler",
  "homepage": "https://xtaskjs.io",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "npm run build --prefix ../core && npm run build --prefix ../typeorm && npm run build --prefix ../queues && rm -rf dist && tsc",
    "prepack": "npm run build",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage --runInBand",
    "coverage:open": "xdg-open coverage/lcov-report/index.html"
  },
  "funding": {
    "type": "opencollective",
    "url": "https://opencollective.com/xtaskjs"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xtaskjs/xtask.git",
    "directory": "packages/event-source"
  },
  "bugs": {
    "url": "https://github.com/xtaskjs/xtask/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "dependencies": {
    "@xtaskjs/core": "^1.0.28",
    "@xtaskjs/queues": "^1.0.7",
    "@xtaskjs/typeorm": "^1.0.16"
  },
  "peerDependencies": {
    "reflect-metadata": "^0.1.12 || ^0.2.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.1.2",
    "@types/jest": "^30.0.0",
    "jest": "^30.1.3",
    "nodemon": "^3.1.10",
    "sqlite3": "^5.1.7",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.27",
    "typescript": "^5.9.2"
  }
}
