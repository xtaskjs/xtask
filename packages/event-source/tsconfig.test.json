{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@xtaskjs/common": ["../common/src"],
      "@xtaskjs/common/*": ["../common/src/*"],
      "@xtaskjs/core": ["../core/src"],
      "@xtaskjs/core/*": ["../core/src/*"],
      "@xtaskjs/typeorm": ["../typeorm/src"],
      "@xtaskjs/typeorm/*": ["../typeorm/src/*"],
      "@xtaskjs/queues": ["../queues/src"],
      "@xtaskjs/queues/*": ["../queues/src/*"]
    }
  },
  "include": [
    "src/**/*",
    "test/**/*",
    "../common/src/**/*",
    "../core/src/**/*",
    "../typeorm/src/**/*",
    "../queues/src/**/*"
  ]
}